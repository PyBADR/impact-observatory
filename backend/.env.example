# =============================================================================
# DecisionCore Intelligence Platform - Environment Configuration Template
# =============================================================================
# Copy this file to .env and configure for your environment
# All variables prefixed with DC7_ are read by the application

# Application
DC7_APP_NAME=DecisionCore Intelligence
DC7_APP_VERSION=1.0.0
DC7_ENVIRONMENT=development
DC7_DEBUG=false
DC7_LOG_LEVEL=INFO

# PostgreSQL + PostGIS Database
# Host and port of PostgreSQL server
DC7_POSTGRES_HOST=localhost
DC7_POSTGRES_PORT=5432
DC7_POSTGRES_DB=decision_core
DC7_POSTGRES_USER=dc7
DC7_POSTGRES_PASSWORD=dc7_pilot_2026

# PostgreSQL Connection Pool
DC7_POSTGRES_POOL_SIZE=20
DC7_POSTGRES_MAX_OVERFLOW=10
DC7_POSTGRES_POOL_PRE_PING=true
DC7_POSTGRES_ECHO=false

# Neo4j Graph Database (for relationship and network analysis)
DC7_NEO4J_URI=bolt://localhost:7687
DC7_NEO4J_USER=neo4j
DC7_NEO4J_PASSWORD=dc7_graph_2026
DC7_NEO4J_POOL_SIZE=50

# Redis (for caching and task queue)
DC7_REDIS_URL=redis://localhost:6379/0
DC7_REDIS_MAX_CONNECTIONS=50
DC7_REDIS_SOCKET_KEEPALIVE=true

# API Configuration
DC7_API_PREFIX=/api/v1
DC7_ALLOWED_ORIGINS=http://localhost:3000
DC7_API_TIMEOUT=30

# External API Keys (optional)
# ACLED - Armed Conflict Location & Event Data
DC7_ACLED_API_KEY=
DC7_ACLED_API_EMAIL=
DC7_ACLED_BASE_URL=https://api.acleddata.com

# =============================================================================
# ENVIRONMENT-SPECIFIC CONFIGURATIONS
# =============================================================================

# DEVELOPMENT
# Uncomment for development environment with relaxed settings
# DC7_ENVIRONMENT=development
# DC7_DEBUG=true
# DC7_LOG_LEVEL=DEBUG
# DC7_POSTGRES_ECHO=true

# PILOT/STAGING
# Uncomment for pilot/staging environment
# DC7_ENVIRONMENT=pilot
# DC7_DEBUG=false
# DC7_LOG_LEVEL=INFO
# DC7_POSTGRES_HOST=pilot-db.example.com
# DC7_NEO4J_URI=bolt://pilot-graph.example.com:7687

# PRODUCTION
# Uncomment for production environment
# DC7_ENVIRONMENT=production
# DC7_DEBUG=false
# DC7_LOG_LEVEL=WARNING
# DC7_POSTGRES_HOST=prod-db.example.com
# DC7_NEO4J_URI=bolt://prod-graph.example.com:7687
# DC7_ALLOWED_ORIGINS=https://app.example.com
