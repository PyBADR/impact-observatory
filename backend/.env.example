# ============================================================================
# Impact Observatory Backend — Environment Configuration Template
# ============================================================================
# Copy to .env: cp .env.example .env

# ── Core ─────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
LOG_LEVEL=info

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=impact_observatory
POSTGRES_USER=observatory_admin
POSTGRES_PASSWORD=changeme

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API Security ─────────────────────────────────────────────────────────────
# Empty = dev mode (full access, no auth required)
# In production: set to a strong random key, e.g. openssl rand -hex 32
API_KEY=

# ── JWT ──────────────────────────────────────────────────────────────────────
# Override in production with a strong random secret
JWT_SECRET_KEY=io-dev-secret-change-in-prod-2026

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://deevo-sim.vercel.app

# ── Real-time data feeds (all optional) ──────────────────────────────────────
ACLED_API_KEY=
ACLED_API_EMAIL=
AISSTREAM_API_KEY=
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
FEED_REFRESH_MINUTES=15

# ── Map tokens (optional) ────────────────────────────────────────────────────
CESIUM_ION_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_CESIUM_TOKEN=
