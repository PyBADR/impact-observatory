{
  "framework": "nextjs",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/.next",
  "installCommand": "cd frontend && npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "${NEXT_PUBLIC_API_URL}/api/:path*"
    },
    {
      "source": "/demo/:path*",
      "destination": "${NEXT_PUBLIC_API_URL}/demo/:path*"
    },
    {
      "source": "/health",
      "destination": "${NEXT_PUBLIC_API_URL}/health"
    }
  ]
}
