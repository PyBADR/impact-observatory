# ============================================================================
# Impact Observatory | مرصد الأثر — Environment Configuration
# ============================================================================
# Copy to .env and fill in values: cp .env.example .env
# All variables are optional unless marked REQUIRED.

# ── Core ─────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
DEBUG=false                  # Enable debug logging (true/false)
LOG_LEVEL=info               # debug | info | warning | error

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=impact_observatory
POSTGRES_USER=observatory_admin
POSTGRES_PASSWORD=changeme   # REQUIRED in production — use a strong random password

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme      # REQUIRED in production — use a strong random password

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API Security ─────────────────────────────────────────────────────────────
# Empty = dev mode (all requests granted CRO access, no auth required).
# REQUIRED in production — set to a strong random string (e.g. openssl rand -hex 32).
API_KEY=

# ── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED in production — override with a strong random secret.
JWT_SECRET_KEY=io-dev-secret-change-in-prod-2026

# ── Backend server ───────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,https://deevo-sim.vercel.app

# ── Simulation limits ─────────────────────────────────────────────────────────
MAX_HORIZON_DAYS=365
DEFAULT_HORIZON_HOURS=336

# ── Real-time data feeds (all optional) ──────────────────────────────────────
# System operates on seed data if these are not configured.
ACLED_API_KEY=               # ACLED conflict events — get key at acleddata.com
ACLED_API_EMAIL=             # ACLED account email
AISSTREAM_API_KEY=           # AISStream.io vessel tracking — aisstream.io
OPENSKY_USERNAME=            # OpenSky Network flights (optional, higher rate limit)
OPENSKY_PASSWORD=
FEED_REFRESH_MINUTES=15

# ── Map / visualization tokens (optional) ────────────────────────────────────
CESIUM_ION_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_CESIUM_TOKEN=

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=         # Optional: passed as X-API-Key header from browser
NEXT_PUBLIC_PRODUCT_NAME=Impact Observatory
