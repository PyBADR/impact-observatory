# ============================================================================
# Impact Observatory | مرصد الأثر — Environment Configuration
# ============================================================================
# Copy to .env and fill in values: cp .env.example .env

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=impact_observatory
POSTGRES_USER=observatory_admin
POSTGRES_PASSWORD=io_pilot_2026

# ── Neo4j ───────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=io_graph_2026

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Backend ─────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000

# ── API Keys (optional) ────────────────────────────────────────────────────
API_KEY=
ACLED_API_KEY=
ACLED_API_EMAIL=

# ── Map Tokens (optional) ──────────────────────────────────────────────────
CESIUM_ION_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_CESIUM_TOKEN=

# ── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_PRODUCT_NAME=Impact Observatory
