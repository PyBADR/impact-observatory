# ══════════════════════════════════════════
# Impact Observatory | مرصد الأثر — Environment Variables
# ══════════════════════════════════════════
# Copy to .env.local and fill in values.
# NEVER commit .env.local to git.

# ── Environment Tier ──
# Options: dev | pilot | prod
IO_TIER=pilot

# ── API Keys ──
# Admin key: full access (run + read + audit)
IO_API_KEY=

# Analyst key: run + read (no manage_users)
IO_ANALYST_KEY=

# Pilot key: read-only demo access
IO_PILOT_KEY=

# ── Frontend ──
# Set to "true" to make frontend call backend API
# instead of running computations client-side
NEXT_PUBLIC_USE_API=false

# ── Backend API URL ──
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ── API Key (used by frontend to authenticate with backend) ──
# NEXT_PUBLIC_IO_API_KEY=

# ── Future: Database (not required for pilot) ──
# DATABASE_URL=
# POSTGRES_URL=

# ── Event Bus (Phase C) ──
# Mode: "memory" (default) | "http" (forward to Railway worker) | "redis"
# EVENT_MODE=memory

# Railway worker URL (only needed when EVENT_MODE=http)
# WORKER_URL=https://your-railway-worker.up.railway.app

# ── Railway Worker ──
# PORT=3001
# WORKER_LOG_LEVEL=info
# REDIS_URL=redis://...
